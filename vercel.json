{
  "buildCommand": "pnpm run build",
  "outputDirectory": "dist/public",
  "rewrites": [
    {
      "source": "/jewelry-cases/(.*)",
      "destination": "/jewelry-cases/$1"
    },
    {
      "source": "/3c-cases/(.*)",
      "destination": "/3c-cases/$1"
    },
    {
      "source": "/(.*)",
      "destination": "/index.html"
    }
  ]
}
